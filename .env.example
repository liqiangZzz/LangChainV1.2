# DeepSeek 模型服务配置
# 本地 .env 可以直接填写真实值；提交到仓库的模板不要写真实 API Key。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MySQL 记忆示例配置
# 仅运行 short_memory/03_short_memory_indb.py、long_memory/03_long_memory_in_db.py
# 或其他 MySQL checkpointer/store 示例时需要。
#
# 推荐在本机 shell / PyCharm 环境变量中配置 MYSQL_USER、MYSQL_PASSWORD 等真实值，
# 再在本地 .env 中通过变量引用拼接连接串，避免把密码写进仓库。
#
# 示例格式：
# MYSQL_DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@localhost:3306/langchain_db?charset=utf8mb4
MYSQL_DATABASE_URL=
